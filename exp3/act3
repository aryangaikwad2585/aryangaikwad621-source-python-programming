principal=float(input("Enter principal amount:"))
monthlyinterest=float(input("Enter monthly interest rate (in %_):"))
year=float(input("enter loan tenure (in years):"))

months = year * 12
monthlyinterest = monthlyinterest / 100

EMI=(principal * monthlyinterest * (1 + monthlyinterest) * months) / ((1 + monthlyinterest) * months - 1)
print("Your EMI is:", round(EMI, 2))
